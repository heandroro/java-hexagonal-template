{
  "role": "Relational persistence adapter — Spring Data JPA + PostgreSQL",
  "includeWhen": "database = postgres",
  "allowedDependencies": ["core", "spring-boot-starter-data-jpa", "postgresql", "mapstruct", "lombok"],
  "packages": {
    "infra.postgres.adapter":    "Outbound adapters (*Adapter) implementing core *Port",
    "infra.postgres.entity":     "JPA @Entity classes",
    "infra.postgres.repository": "Spring Data JpaRepository interfaces",
    "infra.postgres.mapper":     "MapStruct mappers (Core Domain ↔ JPA Entity)"
  },
  "keyClasses": ["UserRepositoryAdapter", "UserEntity", "UserJpaRepository", "UserPostgresMapper"],
  "note": "Only module that uses Lombok — required for mutable JPA entity boilerplate"
}

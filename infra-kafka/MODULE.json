{
  "role": "Async messaging — Spring Kafka with Avro serialization (Confluent Schema Registry)",
  "includeWhen": "broker = kafka",
  "allowedDependencies": ["core", "spring-kafka", "kafka-avro-serializer", "avro", "mapstruct"],
  "packages": {
    "infra.kafka.listener":  "Inbound @KafkaListener (*Listener) — no interface; receives Avro UserEvent",
    "infra.kafka.publisher": "UserKafkaPublisher implementing UserKafkaPublisherPort",
    "infra.kafka.mapper":    "MapStruct mappers (UserEvent Avro ↔ Core Domain / Command)",
    "infra.kafka.avro":      "Generated Avro classes from src/main/avro/*.avsc (build-time)"
  },
  "keyClasses": ["UserEventListener", "UserKafkaPublisher", "UserKafkaMapper", "UserEvent"],
  "avroSchemas": ["src/main/avro/user-event.avsc"],
  "config": {
    "topicProperty": "app.kafka.topics.user-created",
    "topicDefault": "user.created",
    "schemaRegistryProperty": "spring.kafka.consumer.properties.schema.registry.url",
    "schemaRegistryDefault": "http://localhost:8082"
  }
}
